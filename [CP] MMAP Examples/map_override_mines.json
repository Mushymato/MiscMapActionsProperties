{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      "Action": "EditData",
      "Target": "mushymato.MMAP/MapOverrides",
      "Entries": {
        // debug action mushymato.MMAP_UpdateMapOverride Here + mushymato.MMAP.Example_Shed2
        "{{ModId}}_Shed2": {
          "Id": "{{ModId}}_Shed2",
          "ResizeMapIfNeeded": true,
          "SourceMap": "Maps/Woods",
          "SourceRect": {
            "X": 6,
            "Y": 19,
            "Width": 12,
            "Height": 8
          },
          "TargetRect": {
            "X": 10,
            "Y": 10,
            "Width": 12,
            "Height": 8
          }
        }
      }
    },
    {
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}_Shed2_InMines": {
          "Id": "{{ModId}}_Shed2_InMines",
          "Trigger": "LocationChanged",
          // patch in the shed 50% of the time when between floor 10 and floor 20
          "Condition": "LOCATION_MINE_LEVEL Here 10 20, RANDOM 0.5",
          "Actions": [
            "mushymato.MMAP_UpdateMapOverride Here + mushymato.MMAP.Example_Shed2"
          ],
          "MarkActionApplied": false
        },
      },
    }
  ]
}
