{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      // debug action mushymato.MMAP_ShowRenovations Here
      "Action": "EditData",
      "Target": "mushymato.MMAP/MapOverrides",
      "Entries": {
        "{{ModId}}_Chimkins": {
          "Id": "{{ModId}}_Chimkins",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins",
