{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      // debug action mushymato.MMAP_ShowRenovations Here
      "Action": "EditData",
      "Target": "mushymato.MMAP/MapOverrides",
      "Entries": {
        "{{ModId}}_Chimkins": {
          "Id": "{{ModId}}_Chimkins",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins",
          "RemovedById": "{{ModId}}_Chimkins_Remove",
          "TargetRect": {
            "X": 8,
            "Y": 8,
            "Width": 1,
            "Height": 2
          },
          "Renovation": {
            "TargetLocation": "Shed",
            "AddDisplayName": "Add Chimkins",
            "AddDescription": "Add the Chimkins",
            "RemoveDisplayName": "Remove Chimkins",
            "RemoveDescription": "Remove the Chimkins"
          }
        },
        "{{ModId}}_Chimkins_Remove": {
          "Id": "{{ModId}}_Chimkins_Remove",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins_Off",
          "RemovedById": "{{ModId}}_Chimkins",
          "TargetRect": {
            "X": 8,
            "Y": 8,
            "Width": 1,
            "Height": 2
          },
        },
        "{{ModId}}_AddCoop": {
          "Id": "{{ModId}}_AddCoop",
          "SourceMap": "Maps/Coop",
          "TargetRect": {
            "X": 10,
            "Y": 10,
            "Width": 10,
            "Height": 10
          },
          "Renovation": {
            "TargetLocation": "Shed",
            "AddDisplayName": "Add Coop",
            "AddDescription": "Add the Coop",
            "RemoveDisplayName": "Remove Coop",
            "RemoveDescription": "Remove the Coop",
            "Price": 500
          }
        }
      }
    }
  ]
}
