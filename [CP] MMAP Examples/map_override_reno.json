            "X": 2,
            "Y": 2,
            "Width": 1,
            "Height": 2
          },
          "Renovation": {
            "TargetLocation": "Shed",
            "AddDisplayName": "Add Chimkins",
            "AddDescription": "Add the Chimkins",
            "RemoveDisplayName": "Remove Chimkins",
            "RemoveDescription": "Remove the Chimkins"
          }
        },
        "{{ModId}}_Chimkins_Remove": {
          "Id": "{{ModId}}_Chimkins_Remove",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins_Off",
          "RemovedById": "{{ModId}}_Chimkins",
          "TargetRect": {
            "X": 2,
            "Y": 2,
            "Width": 1,
            "Height": 2
          },
        }
      }
    }
  ]
}
