{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      // debug action mushymato.MMAP_ShowRenovations Here
      "Action": "EditData",
      "Target": "mushymato.MMAP/MapOverrides",
      "Entries": {
        "{{ModId}}_Chimkins": {
          "Id": "{{ModId}}_Chimkins",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins",
          "RemovedById": "{{ModId}}_Chimkins_Remove",
          "TargetRect": {
            "X": 8,
            "Y": 1,
            "Width": 1,
            "Height": 2
          },
          "TileRemoveRects": [
            {
              // removes all layers
              "Layer": ".*",
              "TileArea": {
                "X": 7,
                "Y": 0,
                "Width": 3,
                "Height": 4
              }
            },
            {
              // removes all Back and Back[n] layers
              "Layer": "Back\\d*",
              "TileArea": {
                "X": 7,
                "Y": 7,
                "Width": 3,
                "Height": 1
              }
            }
          ],
          "Renovation": {
            "TargetLocationCondition": "mushymato.MMAP_MAP_NAME Here Maps/Shed",
            "AddDisplayName": "Add Chimkins",
            "AddDescription": "Add the Chimkins",
            "AddPlacementText": "Chimkin goes here",
            "RemoveDisplayName": "Remove Chimkins",
            "RemoveDescription": "Remove the Chimkins",
            "RemovePlacementText": "No more chimkins here (or is it???)",
          }
        },
        "{{ModId}}_Chimkins_Remove": {
          "Id": "{{ModId}}_Chimkins_Remove",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins_Off",
          "RemovedById": "{{ModId}}_Chimkins",
          "TargetRect": {
            "X": 8,
            "Y": 8,
            "Width": 1,
            "Height": 2
          },
        },
        "{{ModId}}_AddCoop": {
          "Id": "{{ModId}}_AddCoop",
          "SourceMap": "Maps/Coop",
          "TargetRect": {
            "X": 10,
            "Y": 10,
            "Width": 10,
            "Height": 10
          },
          "Renovation": {
            "TargetLocationCondition": "mushymato.MMAP_MAP_NAME Here Maps/Shed",
            "AddDisplayName": "Add Coop",
            "AddDescription": "Add the Coop",
            "RemoveDisplayName": "Remove Coop",
            "RemoveDescription": "Remove the Coop",
            "Price": 500
          }
        },
        "{{ModId}}_Chimkins_NotRemovable": {
          "Id": "{{ModId}}_Chimkins_NotRemovable",
          "SourceMap": "Maps/{{ModId}}_MO_Chimkins",
          "TargetRect": {
            "X": 6,
            "Y": 6,
            "Width": 1,
            "Height": 2
          },
          "Renovation": {
            "TargetLocationCondition": "mushymato.MMAP_MAP_NAME Here Maps/Shed",
            "AddDisplayName": "Add Chimkins forever",
            "AddDescription": "Add the Chimkins forever and ever",
            "AddPlacementText": "Chimkin goes here (forever)",
            "RemoveCondition": "FALSE"
          }
        },
      }
    }
  ]
}
